# ─────────────────────────────────────────────────────────────────
# SentimentTracker — Environment Configuration Template
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────

# ── Network ──────────────────────────────────────────────────────
# Options: localnet | testnet | mainnet
GENLAYER_NETWORK=localnet

# Custom RPC endpoint (leave blank to use the default for your network)
# GENLAYER_RPC_URL=https://studio.genlayer.com:8443/api

# ── Account ──────────────────────────────────────────────────────
# Your deployer wallet address (set via: genlayer account use <name>)
# GENLAYER_ACCOUNT=my-deployer

# ── Contract ─────────────────────────────────────────────────────
# Deployed contract address (populated after first deploy)
# CONTRACT_ADDRESS=0x...

# ── Dashboard ────────────────────────────────────────────────────
# RPC URL used by the frontend dashboard
DASHBOARD_RPC_URL=http://127.0.0.1:4000/api
DASHBOARD_PORT=5500
